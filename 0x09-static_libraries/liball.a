#include "main.h"

/**
 * _isalpha - Checks for alphabetic characters.
 *
 * @c: the character to be checked.
 * return: 1 for alphabetic character.
 * Return: 0 for anything else.
 */

int _isalpha(int c)
{
	if ((c >= 65 && c <= 98) || (c >= 97 && c <= 122))
	{
		return (1);
	}
	return (0);
}

